# Database — use SQLite for local dev, PostgreSQL for production
# SQLite (local dev):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/virtualfit"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Default store (seeded by prisma/seed.ts)
NEXT_PUBLIC_DEFAULT_STORE_ID="store_default"

# n8n webhook (configured per-store in admin panel)
# These are fallback values; real values are stored in the DB per store
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/tryon"
N8N_WEBHOOK_SECRET="your-secret-key"

# JWT secret for session tokens
SESSION_SECRET="change-this-to-a-random-64-char-string"

# Cron secret (for cleanup endpoints)
CRON_SECRET="change-this-to-a-random-string"
